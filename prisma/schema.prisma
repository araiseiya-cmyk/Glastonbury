datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
// ...（モデルの定義はそのまま）

model Task {
  id                Int      @id @default(autoincrement())
  title             String
  deadline          DateTime
  estimated_minutes Int
  status            String   @default("pending")
  parent_id         Int?
}

model User {
  id   Int    @id @default(autoincrement())
  name String
  age  Int?
}
