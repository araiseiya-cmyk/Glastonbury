<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Task Manager</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #2563eb;       /* テーラードブルー */
      --primary-hover: #1d4ed8;
      --bg: #f8fafc;            /* すっきりした超薄いグレー */
      --card-bg: #ffffff;
      --text-main: #1e293b;
      --text-sub: #64748b;
      --border: #e2e8f0;
    }
    body { 
      font-family: 'Inter', sans-serif; 
      background-color: var(--bg); 
      color: var(--text-main); 
      max-width: 650px; 
      margin: 40px auto; 
      padding: 0 20px; 
    }
    h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--primary);
      text-align: center;
      margin-bottom: 30px;
    }
    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text-main);
      margin-top: 40px;
      margin-bottom: 15px;
    }
    form { 
      display: flex; 
      flex-direction: column; 
      gap: 12px; 
      margin-bottom: 30px; 
      padding: 20px; 
      background: var(--card-bg);
      border: 1px solid var(--border); 
      border-radius: 12px; 
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    label {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-sub);
    }
    input, select {
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus {
      border-color: var(--primary);
    }
    button[type="submit"] {
      background: var(--primary);
      color: white;
      border: none;
      padding: 12px;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 10px;
    }
    button[type="submit"]:hover {
      background: var(--primary-hover);
    }
    #taskList {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .task-item { 
      display: flex; 
      justify-content: space-between; 
      align-items: center; 
      padding: 16px; 
      background: var(--card-bg);
      border: 1px solid var(--border); 
      border-radius: 12px; 
      box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .task-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
    }
    .completed { 
      opacity: 0.6;
      background: #f1f5f9;
    }
    .completed .task-title {
      text-decoration: line-through; 
      color: var(--text-sub); 
    }
    .task-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-main);
    }
    .task-meta {
      font-size: 0.8rem;
      color: var(--text-sub);
      margin-top: 4px;
    }
    .badge { 
      background: #eff6ff; 
      color: var(--primary); 
      padding: 3px 8px; 
      border-radius: 6px; 
      font-size: 11px; 
      font-weight: 600;
      border: 1px solid #dbeafe;
      margin-right: 6px;
    }
    .btn-complete {
      background: white;
      color: var(--primary);
      border: 1px solid var(--primary);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-complete:hover {
      background: var(--primary);
      color: white;
    }
    .text-completed {
      color: #10b981;
      font-size: 0.85rem;
      font-weight: 600;
    }
    .recurring-options {
      display: none; /* 定期チェックボックスがONのときだけJSで表示 */
      border-left: 3px solid var(--primary);
      padding-left: 12px;
      margin-top: 5px;
      gap: 10px;
    }
  </style>
</head>
<body>

  <h1>Smart Task Manager</h1>

  <form id="taskForm">
    <div class="form-group">
      <label for="title">タスク名</label>
      <input type="text" id="title" placeholder="（例）月曜日のミーティング、ジムに行く" required>
    </div>

    <div class="form-row">
      <div class="form-group" id="deadlineGroup">
        <label for="deadline">期限</label>
        <input type="datetime-local" id="deadline" required>
      </div>
      <div class="form-group">
        <label for="estimated_minutes">見積時間（分）</label>
        <input type="number" id="estimated_minutes" placeholder="30" required>
      </div>
    </div>

    <div class="form-group">
      <label for="parent_id">親タスクID（任意）</label>
      <input type="number" id="parent_id" placeholder="親タスクがある場合はIDを入力">
    </div>

    <div class="form-group" style="flex-direction: row; align-items: center; gap: 8px; margin-top: 5px;">
      <input type="checkbox" id="is_recurring" style="width: auto;">
      <label for="is_recurring" style="cursor: pointer; user-select: none;">このタスクを定期的に繰り返す</label>
    </div>

    <div id="recurringOptions" class="recurring-options">
      <div class="form-row">
        <div class="form-group">
          <label for="recurrence_type">繰り返し頻度</label>
          <select id="recurrence_type">
            <option value="daily">毎日</option>
            <option value="weekly">毎週</option>
          </select>
        </div>
        <div class="form-group" id="recurrenceDayGroup" style="display: none;">
          <label for="recurrence_day">曜日</label>
          <select id="recurrence_day">
            <option value="1">月曜日</option>
            <option value="2">火曜日</option>
            <option value="3">水曜日</option>
            <option value="4">木曜日</option>
            <option value="5">金曜日</option>
            <option value="6">土曜日</option>
            <option value="0">日曜日</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="recurrence_time">何時に自動生成しますか？</label>
        <input type="time" id="recurrence_time" value="09:00">
      </div>
    </div>

    <button type="submit">タスクを追加</button>
  </form>

  <h2>おすすめの実行順</h2>
  <div id="taskList"></div>

  <script>
    // 定期チェックボックスのON/OFFで表示を切り替える
    const isRecurringCheckbox = document.getElementById('is_recurring');
    const recurringOptions = document.getElementById('recurringOptions');
    const deadlineGroup = document.getElementById('deadlineGroup');
    const deadlineInput = document.getElementById('deadline');
    const recurrenceTypeSelect = document.getElementById('recurrence_type');
    const recurrenceDayGroup = document.getElementById('recurrence_dayGroup');

    isRecurringCheckbox.addEventListener('change', (e) => {
      if (e.target.checked) {
        recurringOptions.style.display = 'flex';
        recurringOptions.style.styleDoc = 'flex-direction: column';
        deadlineGroup.style.opacity = '0.5';
        deadlineInput.required = false; // 定期タスクの場合、日付は不要（自動生成されるため）
      } else {
        recurringOptions.style.display = 'none';
        deadlineGroup.style.opacity = '1';
        deadlineInput.required = true;
      }
    });

    recurrenceTypeSelect.addEventListener('change', (e) => {
      if (e.target.value === 'weekly') {
        recurrenceDayGroup.style.display = 'flex';
      } else {
        recurrenceDayGroup.style.display = 'none';
      }
    });

    async function loadTasks() {
      const response = await fetch('/tasks');
      const tasks = await response.json();
      const taskList = document.getElementById('taskList');
      taskList.innerHTML = '';

      tasks.forEach((task, index) => {
        const div = document.createElement('div');
        div.className = `task-item ${task.status === 'completed' ? 'completed' : ''}`;
        
        const badge = (index < 3 && task.status === 'pending') ? '<span class="badge">最優先</span> ' : '';

        div.innerHTML = `
          <div>
            <div class="task-title">${badge}${task.title} <small style="color:var(--text-sub); font-weight: normal;">(ID: ${task.id})</small></div>
            <div class="task-meta">
              期限: ${new Date(task.deadline).toLocaleString()} | 見積: ${task.estimated_minutes}分
              ${task.parent_id ? ` | <span style="color: #6366f1;">親: ID ${task.parent_id}</span>` : ''}
            </div>
          </div>
          <div>
            ${task.status === 'pending' 
              ? `<button class="btn-complete" onclick="completeTask(${task.id})">完了する</button>` 
              : '<span class="text-completed">✓ 完了済</span>'}
          </div>
        `;
        taskList.appendChild(div);
      });
    }

    document.getElementById('taskForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = document.getElementById('title').value;
      const deadline = document.getElementById('deadline').value;
      const estimated_minutes = document.getElementById('estimated_minutes').value;
      const parent_id = document.getElementById('parent_id').value;
      const is_recurring = document.getElementById('is_recurring').checked;
      const recurrence_type = document.getElementById('recurrence_type').value;
      const recurrence_day = document.getElementById('recurrence_day').value;
      const recurrence_time = document.getElementById('recurrence_time').value;

      await fetch('/tasks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          title, 
          deadline: is_recurring ? null : deadline, 
          estimated_minutes, 
          parent_id,
          is_recurring,
          recurrence_type: is_recurring ? recurrence_type : null,
          recurrence_day: (is_recurring && recurrence_type === 'weekly') ? recurrence_day : null,
          recurrence_time: is_recurring ? recurrence_time : null
        })
      });

      document.getElementById('taskForm').reset();
      recurringOptions.style.display = 'none';
      deadlineGroup.style.opacity = '1';
      deadlineInput.required = true;
      loadTasks();
    });

    async function completeTask(id) {
      await fetch(`/tasks/${id}`, {
        method: 'PATCH'
      });
      loadTasks();
    }

    loadTasks();
  </script>
</body>
</html>